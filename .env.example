# ═══════════════════════════════════════════════════════════════
#  .env.example — copy to .env and fill in your keys
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════

# ── Jua AI (Person 2 gets this from Jua sponsor table) ──────────
JUA_API_KEY=your_jua_api_key_here

# ── ClickHouse Cloud (Person 2 creates free account at clickhouse.cloud) ──
CLICKHOUSE_HOST=your_instance.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password
CLICKHOUSE_DATABASE=supply_chain

# ── TrueFoundry LLM Gateway (get from TrueFoundry sponsor table) ──
TRUEFOUNDRY_API_KEY=your_truefoundry_api_key_here
TRUEFOUNDRY_BASE_URL=https://llm-gateway.truefoundry.com/api/inference/openai

# ── Pioneer LLM (get from Pioneer sponsor table, use via TrueFoundry) ──
PIONEER_MODEL_NAME=pioneer/pioneer-1

# ── Composio (Person 1 — run: composio add slack) ───────────────
COMPOSIO_API_KEY=your_composio_api_key_here
SLACK_CHANNEL_ID=your_slack_channel_id   # e.g. C08XXXXXXXX

# ── App config ──────────────────────────────────────────────────
DEMO_MODE=false          # set to true before 3-min demo on stage
PORT=8000
